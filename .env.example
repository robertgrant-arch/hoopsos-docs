# HoopsOS — .env.example
# Copy to .env (local) and set in Vercel Environment Variables (preview + prod).
# Locked architecture: Mux + Inngest + Gemini + Clerk (see docs/adr/0001-film-analysis-stack.md).

# --- Database (Neon Postgres) ---
# Pooled connection (pgbouncer) for app runtime
DATABASE_URL=
# Unpooled (direct pg) connection for drizzle-kit migrate / studio
DATABASE_URL_UNPOOLED=

# --- Auth (Clerk) ---
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# --- Asset ingestion (Mux Direct Upload) ---
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SIGNING_SECRET=
# Optional: signing key for signed playback URLs
MUX_SIGNING_KEY_ID=
MUX_SIGNING_KEY_PRIVATE=

# --- Job queue (Inngest) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Notifications (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- AI analysis (Google Gemini) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# --- App ---
NODE_ENV=development
APP_BASE_URL=http://localhost:5173
